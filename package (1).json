  const [screen, setScreen] = useState('welcome');
  const [name, setName] = useState('');
  const [tab, setTab] = useState('chat');

  if (screen === 'welcome') {
    return <Welcome onStart={(n) => { setName(n); setScreen('main'); }} />;
  }

  return (
    <div className="app-shell">
      <header className="app-header">
        <div className="header-left">
          <span className="logo">🩺</span>
          <span className="app-name">Healtho</span>
          <span className="user-name">— {name}</span>
        </div>
        <nav className="tabs">
          {[['chat','💬 Chat'],['checker','🔍 Checker'],['browser','📋 Diseases']].map(([id,label]) => (
            <button key={id} className={`tab-btn ${tab===id?'active':''}`} onClick={() => setTab(id)}>{label}</button>
          ))}
        </nav>
        <button className="exit-btn" onClick={() => { setScreen('welcome'); setName(''); }}>Exit</button>
      </header>

      <main className="app-main">
        {tab === 'chat' && <ChatTab name={name} />}
        {tab === 'checker' && <CheckerTab />}
        {tab === 'browser' && <BrowserTab />}
      </main>
    </div>
  );
}
