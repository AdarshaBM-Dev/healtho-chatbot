  return (
    <div className="welcome-screen">
      <div className="welcome-card">
        <div className="logo-circle">🩺</div>
        <h1>Healtho</h1>
        <p className="subtitle">AI Healthcare Assistant · 41 Diseases · 132 Symptoms</p>
        <div className="welcome-form">
          <label>Your name</label>
          <input value={name} onChange={e => setName(e.target.value)} onKeyDown={e => e.key === 'Enter' && name.trim() && onStart(name.trim())} placeholder="Enter your name..." autoFocus />
          <button className="btn-primary" disabled={!name.trim()} onClick={() => onStart(name.trim())}>
            Start Consultation →
          </button>
        </div>
        <p className="disclaimer">⚠️ Not a substitute for professional medical advice</p>
      </div>
