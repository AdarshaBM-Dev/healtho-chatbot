function ChatTab({ name }) {
  const [messages, setMessages] = useState([{ role: 'assistant', content: `Hi ${name}! 👋 I'm Healtho, your AI health assistant.\n\nDescribe your symptoms and I'll help you understand what might be going on. You can type naturally — for example: "I have headache and fever for 2 days"\n\nWhat's bothering you today?`, type: 'ok' }]);
  const [input, setInput] = useState('');
  const [loading, setLoading] = useState(false);
  const [error, setError] = useState('');
  const chatEndRef = useRef(null);
  const inputRef = useRef(null);

  useEffect(() => { chatEndRef.current?.scrollIntoView({ behavior: 'smooth' }); }, [messages]);

  const send = async () => {
    if (!input.trim() || loading) return;
    const text = input.trim();
    setInput('');
    setError('');
    const userMsg = { role: 'user', content: text };
    const history = messages.map(m => ({ role: m.role, content: m.content }));
    setMessages(prev => [...prev, userMsg]);
    setLoading(true);
    try {
      const data = await sendChatMessage(history, text);
      setMessages(prev => [...prev, { role: 'assistant', content: data.reply, type: data.type, warning: data.warning }]);
    } catch (e) {
      setError(e.message);
      setMessages(prev => [...prev, { role: 'assistant', content: 'Connection error. Please try again.', type: 'error' }]);
    }
    setLoading(false);
  };

  return (
    <div className="chat-screen">
      <div className="chat-messages">
        {messages.map((m, i) => (
          <div key={i} className={`msg-row ${m.role}`}>
            {m.role === 'assistant' && (
              <div className={`avatar ${m.type === 'emergency' ? 'emergency' : ''}`}>
                {m.type === 'emergency' ? '🚨' : '🩺'}
              </div>
            )}
            <div className={`bubble ${m.role} ${m.type || ''}`}>
              {m.warning && <div className="warn-banner">⚠️ {m.warning}</div>}
              <pre style={{ fontFamily: 'inherit', whiteSpace: 'pre-wrap', margin: 0 }}>{m.content}</pre>
            </div>
          </div>
        ))}
        {loading && (
          <div className="msg-row assistant">
            <div className="avatar">🩺</div>
            <div className="bubble assistant loading">
              <span className="dot" /><span className="dot" /><span className="dot" />
            </div>
          </div>
        )}
        <div ref={chatEndRef} />
      </div>
      {error && <div className="error-bar">{error}</div>}
      <div className="chat-input-area">
        <input ref={inputRef} value={input} onChange={e => setInput(e.target.value)} onKeyDown={e => e.key === 'Enter' && send()} placeholder="Describe your symptoms..." disabled={loading} />
        <button className="btn-send" onClick={send} disabled={loading || !input.trim()}>Send</button>
      </div>
    </div>
  );
}

function CheckerTab() {
  const [symInput, setSymInput] = useState('');
  const [suggestions, setSuggestions] = useState([]);
  const [selected, setSelected] = useState([]);
  const [results, setResults] = useState([]);
  const [expanded, setExpanded] = useState(null);

  const handleInput = (val) => {
    setSymInput(val);
    if (val.length < 2) { setSuggestions([]); return; }
    const q = val.toLowerCase().replace(/\s+/g,'_');
    setSuggestions(ALL_SYMPTOMS.filter(s => s.includes(q) || s.replace(/_/g,' ').includes(val.toLowerCase())).slice(0,8));
  };

  const addSym = (s) => {
    if (selected.includes(s)) return;
    const next = [...selected, s];
    setSelected(next);
    setResults(matchLocal(next).map((r,i) => ({...r, rank: i+1})));
    setSymInput(''); setSuggestions([]);
  };

  const removeSym = (s) => {
    const next = selected.filter(x => x !== s);
    setSelected(next);
    setResults(next.length ? matchLocal(next).map((r,i) => ({...r, rank: i+1})) : []);
  };

  return (
    <div className="checker-screen">
      <h2>Symptom Checker</h2>
      <p className="sub">Select symptoms to find matching conditions from 41 diseases</p>

      <div className="search-wrap">
        <input value={symInput} onChange={e => handleInput(e.target.value)} placeholder="Search symptoms (e.g. headache, fever, nausea...)" />
        {suggestions.length > 0 && (
          <div className="suggestions">
            {suggestions.map(s => <button key={s} className="suggestion-item" onClick={() => addSym(s)}>{fmtSym(s)}</button>)}
          </div>
        )}
      </div>

      {selected.length > 0 ? (
        <div className="selected-syms">
          {selected.map(s => (
            <span key={s} className="sym-tag selected">
              {fmtSym(s)}
              <button onClick={() => removeSym(s)} className="remove-sym">×</button>
            </span>
          ))}
          <button className="clear-btn" onClick={() => { setSelected([]); setResults([]); }}>Clear all</button>
        </div>
      ) : (
        <div>
          <p className="section-label" style={{marginBottom:8}}>Common symptoms</p>
          <div className="common-chips">
            {COMMON_SYMPTOMS.map(s => <button key={s} className="chip" onClick={() => addSym(s)}>{fmtSym(s)}</button>)}
          </div>
        </div>
      )}

      {results.length > 0 && (
        <div className="results">
          <p className="results-count">{results.length} possible condition{results.length > 1 ? 's' : ''} found</p>
          {results.map(r => (
            <DiseaseCard key={r.disease} result={r} expanded={expanded === r.disease} onToggle={() => setExpanded(expanded === r.disease ? null : r.disease)} />
          ))}
        </div>
      )}
    </div>
  );
}

function BrowserTab() {
  const [search, setSearch] = useState('');
  const [selected, setSelected] = useState(null);
  const diseases = Object.keys(DISEASE_SYMPTOMS);
  const filtered = search ? diseases.filter(d => d.toLowerCase().includes(search.toLowerCase())) : diseases;

  return (
    <div className="browser-screen">
      <h2>Disease Browser</h2>
      <p className="sub">Browse all 41 diseases in the database</p>
      <input value={search} onChange={e => setSearch(e.target.value)} placeholder="Search diseases..." style={{marginBottom:16}} />
      <div className="disease-grid">
        {filtered.map(d => {
          const risk = RISK_SCORES[d] || RISK_SCORES[d?.trim()] || 50;
          return (
            <button key={d} className={`disease-tile ${selected === d ? 'active' : ''}`} onClick={() => setSelected(selected === d ? null : d)}>
              <div style={{display:'flex',justifyContent:'space-between',alignItems:'center'}}>
                <span style={{fontWeight:500,fontSize:14,textAlign:'left'}}>{d}</span>
                <RiskBadge score={risk} />
              </div>
              <p style={{fontSize:12,color:'#6b7280',marginTop:4}}>{DISEASE_SYMPTOMS[d]?.length} symptoms</p>
            </button>
          );
        })}
      </div>
      {selected && (
        <div className="detail-panel">
          <div style={{display:'flex',justifyContent:'space-between',alignItems:'center',marginBottom:12}}>
            <h3 style={{fontSize:18,fontWeight:600}}>{selected}</h3>
            <button onClick={() => setSelected(null)} style={{background:'none',border:'none',cursor:'pointer',fontSize:20,color:'#9ca3af'}}>×</button>
          </div>
          <p className="section-label">Symptoms ({DISEASE_SYMPTOMS[selected]?.length})</p>
          <div className="sym-grid" style={{marginBottom:16}}>
            {DISEASE_SYMPTOMS[selected]?.map(s => <span key={s} className="sym-tag">{fmtSym(s)}</span>)}
          </div>
          {PRECAUTIONS[selected] && (
            <div className="precaution-box">
              <p className="section-label">Precautions</p>
              <p style={{fontSize:13,color:'#374151',lineHeight:1.6}}>{PRECAUTIONS[selected]}</p>
            </div>
          )}
        </div>
      )}
    </div>
  );
}

