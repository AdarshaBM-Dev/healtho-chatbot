,"silver_like_dusting","small_dents_in_nails","inflammatory_nails","blister","red_sore_around_nose","yellow_crust_ooze"];

const COMMON_SYMPTOMS = ["headache","fever","cough","vomiting","fatigue","nausea","dizziness","chest_pain","joint_pain","skin_rash","diarrhoea","abdominal_pain","breathlessness","itching","back_pain","weight_loss"];

function getRiskColor(s) { return s >= 80 ? '#ef4444' : s >= 60 ? '#f59e0b' : '#10b981'; }
function getRiskLabel(s) { return s >= 80 ? 'HIGH' : s >= 60 ? 'MODERATE' : 'LOW'; }
function fmtSym(s) { return s.replace(/_/g,' '); }

function matchLocal(symptoms) {
  const s = new Set(symptoms.map(x => x.toLowerCase().replace(/\s+/g,'_')));
  return Object.entries(DISEASE_SYMPTOMS).map(([disease, dsyms]) => {
    const matched = dsyms.filter(sym => s.has(sym) || [...s].some(us => sym.includes(us) || us.includes(sym)));
    return { disease, score: matched.length / dsyms.length, matched, total: dsyms.length };
  }).filter(r => r.score > 0).sort((a,b) => b.score - a.score).slice(0, 6);
}

// ─── API SERVICE ─────────────────────────────────────────────────────────────
const API_BASE = process.env.REACT_APP_API_URL || '';

async function sendChatMessage(messages, userMessage) {
  const res = await fetch(`${API_BASE}/api/chat`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ messages, userMessage })
  });
  if (!res.ok) {
    const err = await res.json().catch(() => ({}));
    throw new Error(err.error || 'Server error');
  }
  return res.json();
}

// ─── COMPONENTS ──────────────────────────────────────────────────────────────
function RiskBadge({ score }) {
  return (
    <span style={{ fontSize: 11, fontWeight: 600, padding: '2px 8px', borderRadius: 20, background: getRiskColor(score) + '22', color: getRiskColor(score), border: `1px solid ${getRiskColor(score)}44` }}>
      {getRiskLabel(score)} · {score}%
    </span>
  );
}

function ProgressBar({ value, color }) {
  return (
    <div style={{ height: 4, background: '#e5e7eb', borderRadius: 2, overflow: 'hidden' }}>
      <div style={{ width: `${Math.min(value * 100, 100)}%`, height: '100%', background: color, borderRadius: 2, transition: 'width 0.5s ease' }} />
    </div>
  );
}

function DiseaseCard({ result, expanded, onToggle }) {
  const { disease, score, matched } = result;
  const risk = RISK_SCORES[disease] || RISK_SCORES[disease?.trim()] || 50;
  return (
    <div className="disease-card">
      <button className="disease-card-header" onClick={onToggle}>
        <div style={{ display: 'flex', alignItems: 'center', gap: 10, flex: 1 }}>
          <span className="rank-badge">{result.rank}</span>
          <div style={{ flex: 1 }}>
            <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between', gap: 8 }}>
              <span style={{ fontWeight: 600, fontSize: 15 }}>{disease}</span>
              <RiskBadge score={risk} />
            </div>
            <ProgressBar value={score} color={getRiskColor(risk)} />
            <span style={{ fontSize: 12, color: '#6b7280', marginTop: 2, display: 'block' }}>{matched.length} / {result.total} symptoms matched</span>
          </div>
        </div>
        <span style={{ fontSize: 12, color: '#9ca3af', marginLeft: 8 }}>{expanded ? '▲' : '▼'}</span>
      </button>
      {expanded && (
        <div className="disease-card-body">
          <div className="sym-grid">
            {matched.map(s => <span key={s} className="sym-tag matched">{fmtSym(s)}</span>)}
          </div>
          {PRECAUTIONS[disease] && (
            <div className="precaution-box">
              <p className="section-label">Precautions</p>
              <p style={{ fontSize: 13, color: '#374151', lineHeight: 1.6 }}>{PRECAUTIONS[disease]}</p>
            </div>
          )}
          {risk >= 50 && (
            <div className="risk-box">
              <span>⚠️</span>
              <span style={{ fontSize: 13 }}>
                {risk >= 80 ? 'You should consult a doctor as soon as possible.' : 'Consider consulting a doctor for this condition.'}
              </span>
            </div>
          )}
        </div>
      )}
    </div>
  );
}

// ─── SCREENS ─────────────────────────────────────────────────────────────────
function Welcome({ onStart }) {
